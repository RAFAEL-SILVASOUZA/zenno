OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
DEFAULT_MODEL=llama3.2
MAX_REASONING_ITERATIONS=3
API_HOST=0.0.0.0
API_PORT=8000

# Smart routing
# Heuristic confidence below this threshold falls back to LLM classification.
# Lower = trust heuristics more (faster); higher = ask the LLM more often.
CLASSIFY_HEURISTIC_THRESHOLD=0.7

# Self-consistency: sample N candidates in parallel for math/code/logic
# requests and synthesize the best. Disable to fall back to single-shot CoT.
SELF_CONSISTENCY_ENABLED=true
SELF_CONSISTENCY_MAX_SAMPLES=5

# Sandbox: run python code from the response to verify it actually works.
# Disable in environments where running subprocesses is undesirable.
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=5.0
